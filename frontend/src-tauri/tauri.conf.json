{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gyrobit",
  "version": "0.2.0",
  "identifier": "me.sharik.gyrobit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gyrobit",
        "width": 390,
        "height": 844,
        "minWidth": 320,
        "minHeight": 568,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.ico"
    ]
  }
}
